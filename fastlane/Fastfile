default_platform(:ios)

def api_key
  if ENV["ASC_API_KEY_CONTENT"]
    app_store_connect_api_key(
      key_id:        ENV["ASC_KEY_ID"],
      issuer_id:     ENV["ASC_ISSUER_ID"],
      key_content:   ENV["ASC_API_KEY_CONTENT"],
      is_key_content_base64: true,
    )
  else
    app_store_connect_api_key(
      key_id:        ENV["ASC_KEY_ID"],
      issuer_id:     ENV["ASC_ISSUER_ID"],
      key_filepath:  File.expand_path("~/.appstoreconnect/AuthKey_#{ENV['ASC_KEY_ID']}.p8"),
    )
  end
end

platform :ios do
  desc "Upload IPA to TestFlight (used by CI after xcodebuild)"
  lane :beta do |options|
    ipa_path = options[:ipa] || Dir["#{ENV['RUNNER_TEMP']}/export/*.ipa"].first
    upload_to_testflight(
      api_key:                           api_key,
      ipa:                               ipa_path,
      skip_waiting_for_build_processing: true,
    )
  end

  desc "Build and upload to TestFlight (local use only)"
  lane :release do
    sh("yarn install --frozen-lockfile")
    sh("npx expo prebuild --clean --platform ios")
    sh("cd ios && pod install")
    match(readonly: is_ci)
    increment_build_number(
      build_number: ENV.fetch("BUILD_NUMBER", "1"),
      xcodeproj:    "ios/homelabportal.xcodeproj"
    )
    gym(
      workspace:        "ios/homelabportal.xcworkspace",
      scheme:           "homelabportal",
      configuration:    "Release",
      export_method:    "app-store",
      output_directory: "./build",
      output_name:      "homelabportal.ipa",
      clean:            true
    )
    beta(ipa: "./build/homelabportal.ipa")
  end
end

platform :android do
  desc "Build and upload to Play Store internal track (local use only)"
  lane :release do
    sh("yarn install --frozen-lockfile")
    sh("npx expo prebuild --clean --platform android")

    keystore_path = "/tmp/release.keystore"
    sh("echo $ANDROID_KEYSTORE_BASE64 | base64 --decode > #{keystore_path}")

    gradle(
      project_dir: "android",
      task:        "bundle",
      build_type:  "Release",
      properties: {
        "android.injected.signing.store.file"     => keystore_path,
        "android.injected.signing.store.password" => ENV["ANDROID_KEYSTORE_PASSWORD"],
        "android.injected.signing.key.alias"      => ENV["ANDROID_KEY_ALIAS"],
        "android.injected.signing.key.password"   => ENV["ANDROID_KEY_PASSWORD"],
      }
    )

    supply(
      track:          "internal",
      aab:            "android/app/build/outputs/bundle/release/app-release.aab",
      json_key_data:  ENV["GOOGLE_PLAY_JSON_KEY"],
      release_status: "draft"
    )
  end
end
