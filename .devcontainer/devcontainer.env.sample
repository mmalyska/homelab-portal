# Local development secrets — copy this file to devcontainer.env and fill in the values.
# devcontainer.env is gitignored. In GitHub Codespaces, set these as repository Codespaces secrets instead.
#
# ANDROID_DEBUG_KEYSTORE_PASSWORD=   # Only needed for custom debug keystore; leave blank to use default
# GITHUB_TOKEN=                      # GitHub personal access token for gh CLI (https://github.com/settings/tokens)
